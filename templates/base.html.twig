<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <title>{% block title %}Welcome!{% endblock %}</title>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}
                {{ importmap("app") }}
            {% endblock %}
        {% endblock %}
    </head>

    <body>
        <header>
            {{ include("nav.html.twig") }}
        </header>
        <main>
            {% block main %}
            {% endblock %}
        </main>
    </body>
</html>

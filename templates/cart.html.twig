{% extends "base.html.twig" %}

{% block title %}
    Cart
{% endblock %}

{% block main %}
    <h1>Cart</h1>

    {% for product in cart %}
        <article class="product">
            <div class="info">
                <h2>{{ product.name }}</h2>
                <p>{{ product.description }}</p>
                <data class="price" value="{{ product.price }}">Price: £{{ product.price / 100 }}</data>
            </div>

            {# TODO: better user experience with a custom 'quantity' field and an 'Update" button? #}
            <form method="post" class="qty">
                <button type="submit" name="set" value="{{ product.quantity - 1 }}">-</button>
                <input type="hidden" name="productId" value="{{ product.id }}">
                {{ product.quantity }}
                <button type="submit" name="set" value="{{ product.quantity + 1 }}">+</button>
            </form>
        </article>

		<hr>

        <p>Total: £{{ (product.price * product.quantity) / 100 }}</p>
    {% endfor %}

    {% if cart|length == 0 %}
        <p>Your cart is empty.</p>
    {% endif %}
{% endblock %}
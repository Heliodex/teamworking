{% extends "base.html.twig" %}

{% block title %}
    Cart
{% endblock %}

{% block main %}
    <h1>Cart</h1>

    {% for product in cart %}
        <article class="product">
            <div class="info">
                <h2>{{ product.name }}</h2>
                <p>{{ product.description }}</p>
                <data class="price" value="{{ product.price }}">Price: £{{ product.price / 100 }}</data>
            </div>

            <form method="post">
                <input type="hidden" name="productId" value="{{ product.id }}">
                <button type="submit">Remove from cart</button>
            </form>
        </article>
    {% endfor %}

	{% if cart|length == 0 %}
		<p>Your cart is empty.</p>
	{% endif %}
{% endblock %}
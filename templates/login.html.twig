{% extends "base.html.twig" %}

{% block title %}
    Log in
{% endblock %}

{% block main %}
    <h1>Log in</h1>

    <form method="post">
        {% if error %}
            <ul>
                <li>{{ error.messageKey|trans(error.messageData, "security") }}</li>
            </ul>
        {% endif %}

        <div>
            <label for="username">Username</label>
            <input type="text" value="{{ last_username }}" name="_username" id="username" autocomplete="username" required>
        </div>
        <div>
            <label for="password">Password</label>
            <input type="password" name="_password" id="password" autocomplete="current-password" required>
        </div>
        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

        {#
        Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
        See https://symfony.com/doc/current/security/remember_me.html

        <div class="checkbox mb-3">
        <input type="checkbox" name="_remember_me" id="_remember_me">
        <label for="_remember_me">Remember me</label>
        </div>
        #}

        <button class="btn btn-lg btn-primary" type="submit">
            Log in
        </button>
    </form>
{% endblock %}
